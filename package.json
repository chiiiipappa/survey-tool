{
  "name": "survey-tool",
  "version": "1.0.0",
  "description": "アンケートクロス集計ツール（Electron版）",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "node scripts/prebuild.js",
    "dist": "electron-builder -mw",
    "release": "bash scripts/build-release.sh"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.surveytool.app",
    "productName": "SurveyTool",
    "directories": {
      "output": "dist"
    },
    "afterPack": "scripts/afterPack.js",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "app", "to": "app" },
      { "from": "static", "to": "static" },
      { "from": "sample_data", "to": "sample_data" },
      { "from": "requirements.txt", "to": "requirements.txt" }
    ],
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.business"
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
